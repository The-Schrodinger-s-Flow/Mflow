def watershed_segment(channel):
    # 1. Smooth
    blur = filters.gaussian(channel, sigma=1)
    # 2. Binary mask
    thresh = filters.threshold_otsu(blur)
    binary = blur > thresh
    # 3. Clean noise
    clean = morphology.opening(binary, morphology.disk(1))
    # 4. Distance transform
    dist = ndi.distance_transform_edt(clean)
    # 5. Foreground markers
    dist_norm = dist / dist.max() if dist.max() != 0 else dist
    sure_fg = dist_norm > 0.3
    # 6. Background
    sure_bg = morphology.dilation(clean, morphology.disk(2))
    unknown = sure_bg & (~sure_fg)
    # 7. Markers: label foreground seeds
    markers = measure.label(sure_fg)
    # Background = 0, unknown = 0 already
    # Markers are correct for watershed
    # 8. Watershed
    labels = segmentation.watershed(-dist, markers, mask=clean)
    return labels

# ----------------------------------------
# 4. Segment total cells from green channel
# ----------------------------------------
total_markers = watershed_segment(green)
total_cells = len(np.unique(total_markers[total_markers > 1]))
# imageio.imwrite("clean_green.png", clean)
# imageio.imwrite("markers.png", total_markers)

colored = label2rgb(total_markers, bg_label=0, bg_color=(0, 0, 0), kind="overlay")
imageio.imwrite("live_cells_mask.png", (colored * 255).astype(np.uint8))

# ----------------------------------------
# 5. Segment dead cells from red channel
# ----------------------------------------
dead_markers = watershed_segment(red)
dead_cells = len(np.unique(dead_markers[dead_markers > 1]))

dead_colored = label2rgb(dead_markers, bg_label=0, bg_color=(0, 0, 0), kind="overlay")
imageio.imwrite("dead_cells_mask.png", (dead_colored * 255).astype(np.uint8))
# ----------------------------------------
# 6. Compute live cells and ratio
# ----------------------------------------
live_cells = total_cells - dead_cells
ratio = live_cells / dead_cells if dead_cells > 0 else float("inf")

print("Total cells:", total_cells)
print("Dead cells:", dead_cells)
print("Live cells:", live_cells)
print("Live/Dead ratio:", ratio)
