import os
import numpy as np
import imageio.v2 as imageio
from skimage import filters, morphology, exposure, measure, segmentation, color, util
from skimage.color import label2rgb
from scipy import ndimage as ndi

# ----------------------------------------
# 1. Load JPEG channels from /segmentation folder
# ----------------------------------------
folder = "segmentation"

green_path = os.path.join(folder, "green_live.png")
red_path   = os.path.join(folder, "red_dead.png")

green = imageio.imread(green_path)
red   = imageio.imread(red_path)

# Ensure grayscale
green = util.img_as_ubyte(color.rgb2gray(green)) if green.ndim == 3 else green
red   = util.img_as_ubyte(color.rgb2gray(red)) if red.ndim == 3 else red

# Normalize to 0–255
green = exposure.rescale_intensity(green, out_range=(0, 255)).astype(np.uint8)
red   = exposure.rescale_intensity(red, out_range=(0, 255)).astype(np.uint8)


# ----------------------------------------
# 2. Merge RGB image (for visualization only)
# ----------------------------------------
merged_rgb = np.zeros((*green.shape, 3), dtype=np.uint8)
merged_rgb[:, :, 1] = green
merged_rgb[:, :, 0] = red
imageio.imwrite("merged_live_dead.png", merged_rgb)

